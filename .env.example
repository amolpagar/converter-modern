# ============================================
# DevToolBox Environment Variables
# ============================================

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Rate Limiting (requests per minute per IP)
RATE_LIMIT_RPM=60

# API Key for premium/programmatic access (optional)
API_SECRET_KEY=your-secret-key-here

# App URL (used for sitemap, SEO)
NEXT_PUBLIC_APP_URL=https://devtoolbox.com
